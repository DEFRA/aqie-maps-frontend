{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "aqie-maps-frontend"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <div class="govuk-body" data-testid="app-page-body">
        <p>View current air quality readings from monitoring stations across the UK on an interactive map.</p>
        <a href="/map" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button">
          View map
          <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

{% endblock %}
